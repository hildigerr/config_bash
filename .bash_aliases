alias WARNOFCHANGE='echo Changing directory. . .'

alias cls='clear'
alias CLS='cls'
alias run='clear ; ./a.out'
#alias rdy='./.profile'
alias cdp='WARNOFCHANGE; cd ~/PROGRAMING/Projects'
alias lss='ls | grep'
alias hgrep='history | grep'
alias cvsgrep='cvs status | grep Status'

