#Zelda-Ocarina of Time
alias oot='mupen64plus --fullscreen --nogui ~/Games/ROM/N64/Legend\ of\ Zelda\,\ The\ -\ Ocarina\ of\ Time\ \(U\)\ \(V1.2\)\ \[\!\].z64'

#Star Trek console game in zcode
alias ztrek='frotz ~/Games/IF/z-games/ztrek.z5'


